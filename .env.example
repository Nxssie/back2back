# Discord Bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# Public origin the OAuth flow redirects back to after login (no trailing slash).
# Local dev defaults to the Vite server; in prod set your domain.
FRONTEND_URL=http://localhost:5173

# JWT signing secret. REQUIRED in production: when NODE_ENV=production the
# server refuses to start unless this is a strong secret (>= 32 chars, not the
# default). Generate one with e.g. `openssl rand -hex 32`. Tokens expire in 7d.
JWT_SECRET=

# Moderation — comma-separated Discord user IDs that may delete any room.
# Room creators can always delete their own rooms; these users can delete any.
ADMIN_DISCORD_IDS=

# Empty, idle rooms are auto-removed after this many hours (default 24).
ROOM_TTL_HOURS=24

# Database (libSQL/SQLite). Defaults to ./data/data.db when unset. In Docker,
# docker-compose points it inside the mounted volume (file:/app/data/data.db).
# DATABASE_URL=file:./data/data.db

# Server
PORT=3001
NODE_ENV=development
